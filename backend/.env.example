# Скопируйте этот файл в .env и при необходимости поправьте значения
HTTP_ADDR=:8080

# PostgreSQL
DATABASE_URL=postgres://videohub:videohub@localhost:5432/videohub?sslmode=disable

# Корень папки для статических файлов (видео, превью, аватары)
UPLOADS_DIR=./uploads

# Базовый URL, который backend подставляет в ссылки на файлы
PUBLIC_BASE_URL=http://localhost:8080

# CORS — список origin через запятую (frontend dev-сервер)
CORS_ORIGINS=http://localhost:5173,http://localhost:8081

# Ограничения по размеру файлов (в байтах)
MAX_VIDEO_BYTES=524288000
MAX_IMAGE_BYTES=10485760

# UUID тестового пользователя по умолчанию — используется только для
# обратной совместимости публичных эндпоинтов без авторизации.
DEFAULT_USER_ID=11111111-1111-1111-1111-111111111111

# Если true — при старте таблицы пересоздадутся (DROP ALL) и наполнятся seed.
RESEED_ON_START=false

# ---- Auth ----
# Секрет HMAC для подписи JWT. В проде задайте длинную случайную строку.
JWT_SECRET=videohub-dev-secret-change-me
# Срок жизни выданного JWT в часах.
JWT_TTL_HOURS=168

# Учётка администратора, которой можно войти по логину/паролю.
# Хэш для admin1 закладывается в seed; здесь только имя для документации.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1

# Время жизни кода подтверждения email в минутах.
AUTH_CODE_TTL_MIN=10

# В демо-режиме backend возвращает сгенерированный код прямо в ответе
# (поле devCode) и пишет его в лог — для работы без SMTP.
# В проде поставьте false и подключите отправку письма.
AUTH_EXPOSE_CODE=true
